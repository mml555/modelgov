{
  "name": "modelgov",
  "version": "1.7.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.19.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "generate-sdk-types": "tsx scripts/generate-sdk-types.ts",
    "build": "pnpm generate-sdk-types && pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint packages apps examples scripts --max-warnings 0",
    "check:file-sizes": "bash scripts/check-file-sizes.sh",
    "test": "bash scripts/vitest-with-db.sh",
    "test:coverage": "bash scripts/vitest-with-db.sh --coverage",
    "test:db": "bash scripts/test-with-db.sh",
    "smoke:ci": "bash scripts/smoke-ci.sh",
    "smoke:compose-e2e": "bash scripts/example-e2e-ci.sh",
    "test:packages": "pnpm exec vitest run packages/cli/test packages/sdk-typescript/test packages/create-modelgov/test apps/operator-console/test",
    "verify": "pnpm build && pnpm typecheck && pnpm lint && pnpm check:file-sizes && pnpm test:packages && pnpm test:coverage && pnpm --filter @modelgov/api openapi:export && bash scripts/verify-versions.sh && pnpm exec tsx scripts/doctor-production-example.ts && OPENAI_API_KEY=x ANTHROPIC_API_KEY=x pnpm modelgov validate --config modelgov.production.example.yaml --production",
    "doctor:production": "pnpm modelgov doctor production",
    "test:watch": "vitest",
    "dev": "pnpm --filter @modelgov/api dev",
    "db:init": "pnpm --filter @modelgov/api db:init",
    "modelgov": "pnpm --filter @modelgov/cli dev --",
    "setup": "./setup",
    "start": "pnpm modelgov up simple",
    "stop": "pnpm modelgov down simple",
    "up": "pnpm modelgov up simple",
    "up:full": "pnpm modelgov up full",
    "up:local": "pnpm modelgov up local",
    "up:cloud": "pnpm modelgov up cloud",
    "reload-providers": "pnpm modelgov reload-providers",
    "up:azure": "pnpm modelgov up azure",
    "status": "pnpm modelgov status simple",
    "doctor": "pnpm modelgov doctor simple",
    "smoke": "pnpm modelgov smoke simple",
    "build-image": "bash scripts/build-api-image.sh",
    "down": "pnpm modelgov down simple",
    "down:full": "pnpm modelgov down full",
    "down:local": "pnpm modelgov down local",
    "down:cloud": "pnpm modelgov down cloud",
    "down:azure": "pnpm modelgov down azure"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "typescript-eslint": "^8.18.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "wait-on": "^8.0.1"
  }
}
