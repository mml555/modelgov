# The chatbot UI talks to your Ai-Guard gateway (not the model directly).
AI_GUARD_URL=http://localhost:3000
AI_GUARD_API_KEY=sk-ai-guard-api-local

# ── Backend provider (compose) ───────────────────────────────────────────────
# Default is local Ollama (no key). To use a real provider, point LiteLLM at a
# different config and supply its key(s):
#   LITELLM_CONFIG=./litellm.openrouter.yaml
#   OPENROUTER_API_KEY=sk-or-...
# or Azure:
#   LITELLM_CONFIG=./litellm.azure.yaml
#   AZURE_API_KEY=...
#   AZURE_API_BASE=https://<resource>.openai.azure.com
#   AZURE_API_VERSION=2024-08-01-preview
