# Point these at your running Ai-Guard gateway (which must load THIS folder's
# ai-guard.yaml). With the local Ollama stack, the defaults below just work.
AI_GUARD_URL=http://localhost:3000
AI_GUARD_API_KEY=sk-ai-guard-api-local

# Postgres/pgvector connection for the KB store. Run a pgvector container:
#   docker run -d --name rag-pgvector -p 5433:5432 \
#     -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=ragkb pgvector/pgvector:pg16
RAG_DATABASE_URL=postgres://postgres:postgres@localhost:5433/ragkb

# Port the demo widget server listens on.
PORT=3005
