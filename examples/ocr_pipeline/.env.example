# Point these at your running Ai-Guard gateway (which must load THIS folder's
# ai-guard.yaml, with a vision model mapped in litellm.ollama.yaml).
AI_GUARD_URL=http://localhost:3000
AI_GUARD_API_KEY=sk-ai-guard-api-local

# Vision payloads (base64 page images) exceed the gateway's 1 MiB default body
# limit — set this on the GATEWAY (not this app) so full-page scans aren't
# rejected with 413. ~16 MiB comfortably fits a 150-DPI page.
REQUEST_BODY_LIMIT_BYTES=16777216
