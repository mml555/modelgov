# Zero-secret local development defaults used by ./setup.
OPENAI_API_KEY=demo-unused
ANTHROPIC_API_KEY=demo-unused
LITELLM_MASTER_KEY=sk-modelgov-local

PORT=3000
MODELGOV_API_KEY=sk-modelgov-api-local
DATABASE_URL=postgres://postgres:postgres@localhost:5432/modelgov
LITELLM_BASE_URL=http://localhost:4000
MODELGOV_CONFIG=modelgov.yaml
REQUEST_BODY_LIMIT_BYTES=1048576
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_MS=60000

PRESIDIO_ANALYZER_URL=http://localhost:5002
PRESIDIO_ANONYMIZER_URL=http://localhost:5001

# Operator console (browser on :5174 calls API on :3090)
CORS_ALLOW_ORIGINS=http://localhost:5174,http://127.0.0.1:5174
