# ── Provider keys (consumed by the LiteLLM proxy) ───────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── LiteLLM proxy ───────────────────────────────────────────────────────────
# Shared secret between the Modelgov API and the LiteLLM proxy.
LITELLM_MASTER_KEY=sk-modelgov-local

# ── Modelgov API (used when running locally without Docker) ─────────────────
PORT=3000
MODELGOV_API_KEY=sk-modelgov-api-local
# Optional production form: scoped keys. When set, this overrides the single
# fallback key above. Keep this JSON on one line for dotenv compatibility.
# MODELGOV_API_KEYS=[{"name":"prod-app","key":"replace-me","projectId":"my-project","environment":"production","allowedUserTypes":["logged_in"],"permissions":["chat:create"]}]
DATABASE_URL=postgres://postgres:postgres@localhost:5432/modelgov
LITELLM_BASE_URL=http://localhost:4000
MODELGOV_CONFIG=modelgov.yaml
REQUEST_BODY_LIMIT_BYTES=1048576
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_MS=60000
# Optional — shared rate limits across API replicas (recommended in production)
# REDIS_URL=redis://localhost:6379

# ── Budget alerts (optional) ────────────────────────────────────────────────
# BUDGET_ALERT_WEBHOOK_URL=https://hooks.example.com/budget
# BUDGET_ALERT_WEBHOOK_SECRET=your-hmac-secret

# ── Safety (Presidio) ───────────────────────────────────────────────────────
PRESIDIO_ANALYZER_URL=http://localhost:5002
PRESIDIO_ANONYMIZER_URL=http://localhost:5001

# ── Observability / Langfuse (full mode only) ───────────────────────────────
# `make up-full` provisions Langfuse + its API keys automatically — you don't
# need to set anything here. Uncomment only to override the seeded keys or to
# point at an existing Langfuse (e.g. Langfuse Cloud):
# OBSERVABILITY_PROVIDER=langfuse
# LANGFUSE_HOST=https://cloud.langfuse.com
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# OBSERVABILITY_CAPTURE_CONTENT=false
# When true, model completions are stored in the idempotency table for replays.
# IDEMPOTENCY_CAPTURE_CONTENT=false
# Fail boot when modelgov.yaml references models missing from PRICE_TABLE.
# STRICT_PRICING=false
