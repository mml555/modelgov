# Minimal DEV env. The full production reference (Redis, Stripe billing, OIDC,
# TLS, metrics auth, retention knobs, …) lives in .env.production.example.

# ── Provider keys (consumed by the LiteLLM proxy) ───────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
# Azure OpenAI (use `make start-azure` — see .env.azure.example):
# AZURE_API_KEY=...
# AZURE_API_BASE=https://<resource>.openai.azure.com
# AZURE_API_VERSION=2024-08-01-preview

# ── LiteLLM proxy ───────────────────────────────────────────────────────────
# Shared secret between the Modelgov API and the LiteLLM proxy.
LITELLM_MASTER_KEY=sk-modelgov-local

# ── Modelgov API (used when running locally without Docker) ─────────────────
PORT=3000
MODELGOV_API_KEY=sk-modelgov-api-local
# Optional production form: scoped keys. When set, this overrides the single
# fallback key above. Keep this JSON on one line for dotenv compatibility.
# MODELGOV_API_KEYS=[{"name":"prod-app","key":"replace-me","projectId":"my-project","environment":"production","allowedUserTypes":["logged_in"],"permissions":["chat:create"]}]
DATABASE_URL=postgres://postgres:postgres@localhost:5432/modelgov
LITELLM_BASE_URL=http://localhost:4000
MODELGOV_CONFIG=modelgov.yaml
REQUEST_BODY_LIMIT_BYTES=1048576
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_MS=60000
# Optional — shared rate limits across API replicas (recommended in production)
# REDIS_URL=redis://localhost:6379

# ── Budget alerts (optional) ────────────────────────────────────────────────
# BUDGET_ALERT_WEBHOOK_URL=https://hooks.example.com/budget
# BUDGET_ALERT_WEBHOOK_SECRET=your-hmac-secret

# ── Safety (Presidio) ───────────────────────────────────────────────────────
PRESIDIO_ANALYZER_URL=http://localhost:5002
PRESIDIO_ANONYMIZER_URL=http://localhost:5001

# ── Observability / Langfuse (full mode only) ───────────────────────────────
# `make up-full` provisions Langfuse + its API keys automatically — you don't
# need to set anything here. Uncomment only to override the seeded keys or to
# point at an existing Langfuse (e.g. Langfuse Cloud):
# OBSERVABILITY_PROVIDER=langfuse
# LANGFUSE_HOST=https://cloud.langfuse.com
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# OBSERVABILITY_CAPTURE_CONTENT=false
# When true, model completions are stored in the idempotency table for replays.
# IDEMPOTENCY_CAPTURE_CONTENT=false
# Fail boot when modelgov.yaml references models missing from PRICE_TABLE.
# STRICT_PRICING=false

# ── Document-AI providers (optional; governed OCR / extraction) ─────────────
# Enable a provider by configuring it, then call POST /v1/documents/extract.
# Governed like an LLM call: budget-enforced, metered per page, PII-masked.
# Self-hosted Tesseract OCR sidecar (POST {url}/extract):
# TESSERACT_URL=http://tesseract:8080
# Azure Document Intelligence (the customer's system):
# AZURE_DI_ENDPOINT=https://your-di.cognitiveservices.azure.com
# AZURE_DI_KEY=your-key
# Amazon Textract (SigV4, no AWS SDK). Enabled only when TEXTRACT_REGION + creds set;
# supports base64, https url, and s3://bucket/key sources.
# TEXTRACT_REGION=us-east-1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# s3:// sources are rejected unless the bucket is allowlisted (fail closed):
# TEXTRACT_S3_ALLOWED_BUCKETS=my-scans-bucket
# Per-page USD cost basis (reserve/settle); Tesseract is free (self-hosted).
# DOCUMENT_PRICE_PER_PAGE_AZURE_DI=0.0015
# DOCUMENT_PRICE_PER_PAGE_TEXTRACT=0.0015
# Worst-case pages reserved per request (budget-cap floor; default 30).
# DOCUMENT_MAX_PAGES=30

# ── Cost attribution (optional) ─────────────────────────────────────────────
# Group gateway calls into a business "transaction" by reusing one x-request-id
# across them, then read per-transaction cost at GET /v1/usage/transactions.
# To also fold in externally-tracked non-LLM cost (e.g. Azure Document
# Intelligence) via POST /v1/usage/external, set an allowlist of sources —
# leaving it unset disables that endpoint (fails closed).
# EXTERNAL_COST_SOURCES=azure-di,textract
# Per-row sanity cap (USD) on ingested external cost (default 100).
# EXTERNAL_COST_MAX_USD=100
