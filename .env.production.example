# Production environment for docker-compose.production.yml
# Copy to .env.production and fill every value marked REQUIRED.

# ── Images ───────────────────────────────────────────────────────────────────
# Pin EVERY image to an immutable digest (image@sha256:...) in production — never
# a floating tag like :latest or :main-stable, which mutate under you.
# CI publishes modelgov-api on version tags and commit SHAs (no :latest).
MODELGOV_API_IMAGE=ghcr.io/your-org/modelgov-api@sha256:REPLACE_WITH_DIGEST
# Local build without a registry:
# MODELGOV_API_IMAGE=modelgov-api:local
# BUILD_LOCAL_IMAGE=true
POSTGRES_IMAGE=postgres:16-alpine@sha256:REPLACE_WITH_DIGEST
# Scanner-clean alternative (no gosu; same POSTGRES_* env vars). Resolve a digest:
#   docker pull cgr.dev/chainguard/postgres:latest
#   docker inspect cgr.dev/chainguard/postgres:latest --format='{{index .RepoDigests 0}}'
# POSTGRES_IMAGE=cgr.dev/chainguard/postgres@sha256:REPLACE_WITH_DIGEST
# Migrating an existing pgdata volume from official postgres may require a
# collation refresh (see Chainguard postgres image docs). Managed Postgres is
# still preferred over either container image for production.
REDIS_IMAGE=redis:7-alpine@sha256:REPLACE_WITH_DIGEST
LITELLM_IMAGE=ghcr.io/berriai/litellm@sha256:REPLACE_WITH_DIGEST
PRESIDIO_ANALYZER_IMAGE=mcr.microsoft.com/presidio-analyzer@sha256:REPLACE_WITH_DIGEST
PRESIDIO_ANONYMIZER_IMAGE=mcr.microsoft.com/presidio-anonymizer@sha256:REPLACE_WITH_DIGEST

# ── Production hardening ─────────────────────────────────────────────────────
MODELGOV_PRODUCTION=true
# Deployment profile (flat budgets default for both):
#   selfhost    — single-tenant self-host (see deploy/helm/modelgov/values-selfhost.yaml)
#   multitenant — SaaS control plane (see values-multitenant.yaml)
# MODELGOV_DEPLOY_PROFILE=selfhost
# Set when behind a load balancer (requires TRUST_PROXY):
# MODELGOV_BEHIND_PROXY=true
# TRUST_PROXY=10.0.0.0/8
# One-time bootstrap admin key in env (then issue keys from DB):
# ALLOW_BOOTSTRAP_ADMIN_KEY=true

# ── Public port (behind TLS terminator in real prod) ───────────────────────
MODELGOV_PUBLIC_PORT=3000

# ── Secrets (REQUIRED) ─────────────────────────────────────────────────────
# Recommended: seed ONE bootstrap key with keys:admin, then issue/rotate/revoke
# every other key from the DB store (modelgov keys ... / POST /v1/admin/keys).
# MODELGOV_API_KEYS=[{"name":"bootstrap-admin","key":"REPLACE","permissions":["keys:admin","usage:read"]}]
MODELGOV_API_KEY=REPLACE_WITH_LONG_RANDOM_SECRET
# Or scoped keys (one line JSON) — see docs/configuration.md#scoped-api-keys-multi-tenant-operators
# MODELGOV_API_KEYS=[{"name":"ops","key":"REPLACE","permissions":["chat:create","usage:read"]},{"name":"tenant-a","key":"REPLACE","projectId":"tenant-a","permissions":["chat:create"]}]

# DB-backed key store (see docs/operations.md#api-key-management)
API_KEYS_DB_ENABLED=true
API_KEY_CACHE_TTL_MS=10000

# ── Operator SSO (OIDC) — optional (see docs/operations.md#operator-sso-oidc--rbac)
# When set, operators authenticate with a corporate-IdP JWT instead of an API key.
# OIDC_ISSUER=https://login.example.com/
# OIDC_JWKS_URI=https://login.example.com/.well-known/jwks.json
# OIDC_AUDIENCE=modelgov
# OIDC_AUDIENCE_OPTIONAL=true   # local dev only — do NOT use in production
# OIDC_ROLES_CLAIM=roles
# OIDC_ROLE_MAP={"modelgov-admins":"owner","modelgov-finops":"finops"}
# Bind an OIDC operator to a tenant via a token claim. When set and present, the
# operator is locked to that tenant and cannot use X-Modelgov-Tenant to switch.
# Leave unset for platform-only SSO (tenant switching then needs the
# `tenant:switch` permission, granted to the `owner` role only).
# OIDC_TENANT_CLAIM=tenant_id

# Extra env-var names a policy `env/VAR` provider key may reference, beyond the
# default (names ending in _KEY). Gateway secrets (DATABASE_URL,
# STRIPE_SECRET_KEY, LITELLM_MASTER_KEY, ...) are always denied.
# MODELGOV_POLICY_ENV_ALLOWLIST=MY_PROVIDER_TOKEN

# ── OpenTelemetry tracing — optional (provider: otel)
# OBSERVABILITY_PROVIDER=otel
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
# OTEL_SERVICE_NAME=modelgov

# ── Hierarchical (node-tree) budgets — optional (see docs/design/multi-tenancy.md)
# When on, requests with a budgetNodeId (body or key-bound) enforce against the
# budget_nodes tree instead of the flat dimensions. Flat path stays the default.
# HIERARCHICAL_BUDGETS=true

# ── Dynamic policy store — optional (see docs/design/dynamic-policy.md)
# Store policy as versioned rows in Postgres instead of a file baked into the
# image. Required for hot reload, approvals, and per-tenant policy below.
# POLICY_STORE_ENABLED=true
#
# Zero-restart hot reload (default ON when the store is enabled): an activated
# version applies without a restart — resolved per request (TTL-cached) and
# propagated to every replica instantly via Postgres LISTEN/NOTIFY. Set false to
# keep the boot-config path (activation applies on the next rolling restart).
# POLICY_HOT_RELOAD=false
#
# Two-person rule (default off): a saved version is `proposed` and must be
# approved by a DIFFERENT operator holding policy:approve before it can be
# activated. Grant policy:approve via the `policy-approver` role, kept separate
# from `policy-admin` (which authors but cannot approve).
# POLICY_APPROVAL_REQUIRED=true
#
# Per-tenant policy (see docs/design/multi-tenancy.md): evaluate each request
# against its tenant's active version. POLICY_CACHE_TTL_MS is the backstop bound
# on hot-reload convergence if a NOTIFY is missed.
# MULTI_TENANT_POLICY=true
# POLICY_CACHE_TTL_MS=30000

# ── Tenant-isolation RLS on config_versions — optional, defense-in-depth
# Installs the RLS policy at migrate time and sets app.current_tenant per
# transaction. Only enforces when the app connects as a NON-OWNER DB role
# (the table owner bypasses RLS). See docs/design/multi-tenancy.md.
# DB_RLS_ENABLED=true

DATABASE_URL=postgres://postgres:REPLACE_DB_PASSWORD@postgres:5432/modelgov
POSTGRES_PASSWORD=REPLACE_DB_PASSWORD
POSTGRES_DB=modelgov
# TLS to the database.
#   - Bundled `postgres` service (this file's default DATABASE_URL): it ships
#     with SSL OFF, so use "disable" on the private compose network and set
#     DATABASE_SSL_DISABLE_ALLOWED=true to acknowledge it. `require` here would
#     crash-loop the API ("server does not support SSL connections").
#   - Managed / REMOTE Postgres (RDS, Cloud SQL, ...): use "verify-full" with
#     DATABASE_SSL_CA. The boot guard REFUSES "disable" (and bare "require",
#     which doesn't verify the cert) against a remote host — so you cannot
#     accidentally ship an unverified connection.
DATABASE_SSL=disable
DATABASE_SSL_DISABLE_ALLOWED=true
# For managed Postgres, instead use:
# DATABASE_SSL=verify-full
# DATABASE_SSL_CA=/etc/ssl/certs/rds-ca.pem

LITELLM_MASTER_KEY=REPLACE_LITELLM_MASTER_KEY
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Tuning ─────────────────────────────────────────────────────────────────
REQUEST_BODY_LIMIT_BYTES=1048576
# Slow-client (slowloris) backstop for receiving the request; 0 disables.
REQUEST_TIMEOUT_MS=60000
# Whom to trust for the client IP. MUST be your proxy's IP/CIDR list (or a hop
# count) behind a load balancer — leaving it unset (false) means X-Forwarded-For
# is ignored so callers can't spoof their IP to evade rate limits.
# TRUST_PROXY=10.0.0.0/8
# Per-call upstream timeout to the LiteLLM proxy.
LITELLM_TIMEOUT_MS=60000
# DB pool bounds (see docs/operations.md).
DB_POOL_MAX=10
DB_CONNECTION_TIMEOUT_MS=5000
DB_STATEMENT_TIMEOUT_MS=30000
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_MS=60000
# Rate-limit posture when Redis is unreachable. false = fail CLOSED (reject);
# true = fail open (the atomic budget reserve is still the real spend guard).
RATE_LIMIT_FAIL_OPEN=false
# Comma-separated allowlist of browser origins for CORS (empty = no CORS headers).
# CORS_ALLOW_ORIGINS=https://app.example.com
MAINTENANCE_ENABLED=true
IDEMPOTENCY_STALE_MS=900000
# Completed idempotency replay rows older than this are pruned (default 7d).
IDEMPOTENCY_COMPLETED_RETENTION_MS=604800000
RESERVATION_STALE_MS=900000
# Audit-log retention; the maintenance sweep prunes request_logs older than this
# (default 30 days). Lower it if the audit table growth is a concern.
REQUEST_LOG_RETENTION_MS=2592000000

# ── Multi-replica (recommended for production) ───────────────────────────────
REDIS_URL=redis://redis:6379

# ── Budget alerts ────────────────────────────────────────────────────────────
# POST once per month when global spend crosses alert_at_percent in modelgov.yaml
# BUDGET_ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...
# BUDGET_ALERT_WEBHOOK_SECRET=replace-with-hmac-secret
# Startup rejects webhook URLs on private/link-local hosts (SSRF guard). Only set
# this true if you intentionally target an internal collector.
# BUDGET_ALERT_WEBHOOK_ALLOW_PRIVATE=false

# ── Stripe billing (optional; enable billing: in modelgov.yaml) ────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── Document-AI providers — governed OCR / extraction — optional ────────────
# (see docs/design/document-ai.md). Enable a provider by configuring it; then
# POST /v1/documents/extract is budget-enforced, metered per page, PII-masked.
# TESSERACT_URL=http://tesseract:8080
# AZURE_DI_ENDPOINT=https://your-di.cognitiveservices.azure.com
# AZURE_DI_KEY=your-key
# Amazon Textract — enabled only when TEXTRACT_REGION + AWS creds are set:
# TEXTRACT_REGION=us-east-1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# s3:// sources rejected unless the bucket is allowlisted (fail closed):
# TEXTRACT_S3_ALLOWED_BUCKETS=my-scans-bucket
# DOCUMENT_PRICE_PER_PAGE_AZURE_DI=0.0015
# DOCUMENT_PRICE_PER_PAGE_TEXTRACT=0.0015
# DOCUMENT_MAX_PAGES=30

# ── Cost attribution — external (non-LLM) cost ingestion — optional ─────────
# (see docs/design/cost-attribution.md). Correlation/rollup reads are always on;
# set an allowlist to enable POST /v1/usage/external (unset = fails closed).
# EXTERNAL_COST_SOURCES=azure-di,textract
# EXTERNAL_COST_MAX_USD=100

OBSERVABILITY_CAPTURE_CONTENT=false

# ── Metrics ──────────────────────────────────────────────────────────────────
# In production, /metrics requires METRICS_AUTH_TOKEN unless
# METRICS_ALLOW_PUBLIC=true is explicitly set for a private scrape network.
METRICS_ENABLED=true
# METRICS_AUTH_TOKEN=replace-with-long-random-secret
# METRICS_ALLOW_PUBLIC=false

# ── Logging ──────────────────────────────────────────────────────────────────
# Structured JSON (pino). fatal|error|warn|info|debug|trace|silent (default info).
# LOG_LEVEL=info

# When true, idempotency replays include model completion text at rest.
IDEMPOTENCY_CAPTURE_CONTENT=false

# Fail boot when configured models are missing from the static PRICE_TABLE.
STRICT_PRICING=false

# ── Observability (optional) ───────────────────────────────────────────────
OBSERVABILITY_PROVIDER=none
# OBSERVABILITY_PROVIDER=langfuse
# LANGFUSE_HOST=https://cloud.langfuse.com
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
OBSERVABILITY_CAPTURE_CONTENT=false
