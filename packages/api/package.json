{
  "name": "@modelgov/api",
  "version": "1.4.0",
  "license": "MIT",
  "description": "Modelgov API: stateful control plane (Postgres + LiteLLM + Safety).",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup && rm -rf dist/migrations && cp -R src/db/migrations dist/migrations",
    "typecheck": "tsc --noEmit",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "migrate": "node dist/migrate.js",
    "openapi:export": "node dist/openapiExport.js",
    "audit:export": "tsx scripts/export-audit-log.ts",
    "db:init": "tsx src/migrate.ts"
  },
  "dependencies": {
    "@modelgov/policy-engine": "workspace:*",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.7.0",
    "fastify": "^5.2.0",
    "ioredis": "^5.4.2",
    "jose": "^5.9.6",
    "langfuse": "^3.29.0",
    "pg": "^8.13.1",
    "prom-client": "^15.1.3",
    "undici": "^6.21.3",
    "yaml": "^2.6.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10"
  }
}
