{
  "name": "create-modelgov",
  "version": "1.6.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mml555/modelgov.git",
    "directory": "packages/create-modelgov"
  },
  "description": "Scaffold an modelgov.yaml + .env for a new project.",
  "type": "module",
  "bin": {
    "create-modelgov": "./dist/index.js"
  },
  "files": [
    "dist",
    "src/render.ts",
    "src/templates.ts"
  ],
  "exports": {
    ".": "./dist/index.js",
    "./render": "./src/render.ts",
    "./templates": "./src/templates.ts",
    "./litellm": "./src/litellm.ts"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --clean",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@clack/prompts": "^0.8.2",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@modelgov/policy-engine": "workspace:*"
  }
}
