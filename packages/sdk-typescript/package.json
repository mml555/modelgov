{
  "name": "@modelgov/sdk",
  "version": "1.4.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mml555/modelgov.git",
    "directory": "packages/sdk-typescript"
  },
  "description": "Modelgov API client. `feature` and `userType` are mandatory at the type level.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm run -w generate-sdk-types && tsup src/index.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit"
  }
}
