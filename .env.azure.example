# Azure OpenAI dev env for `make start-azure` / `modelgov up azure`.
# Deployment names in modelgov.azure.example.yaml must match your resource.

# ── Azure OpenAI (consumed by the LiteLLM proxy) ────────────────────────────
AZURE_API_KEY=
AZURE_API_BASE=https://<your-resource>.openai.azure.com
AZURE_API_VERSION=2024-08-01-preview

# ── LiteLLM proxy ───────────────────────────────────────────────────────────
LITELLM_MASTER_KEY=sk-modelgov-local

# ── Modelgov API ─────────────────────────────────────────────────────────────
PORT=3000
MODELGOV_API_KEY=sk-modelgov-api-local
DATABASE_URL=postgres://postgres:postgres@localhost:5432/modelgov
LITELLM_BASE_URL=http://localhost:4000
MODELGOV_CONFIG=modelgov.azure.example.yaml
REQUEST_BODY_LIMIT_BYTES=1048576
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_MS=60000

# ── Safety (Presidio) ───────────────────────────────────────────────────────
PRESIDIO_ANALYZER_URL=http://localhost:5002
PRESIDIO_ANONYMIZER_URL=http://localhost:5001
